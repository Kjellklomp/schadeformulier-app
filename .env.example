# Server-side only — never exposed to the browser. Used by app/api/vision/route.ts
# for the AI-vision calls (rijbewijs/kenteken/verzekering OCR, toedracht-analyse, conflictcheck).
ANTHROPIC_API_KEY=

# Upstash Redis, used by app/api/session/[id]/route.ts for the QR-samen-invullen-sessie
# (TTL ~24 uur). Add the "Redis" integration (by Upstash) from the Vercel Marketplace to
# your project and these are injected automatically — copy the values here for local dev.
# The app also accepts the legacy KV_REST_API_URL / KV_REST_API_TOKEN names if that's
# what your integration provides instead.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
